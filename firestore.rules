rules_version = '2';
// Duren Phase 0 — Firestore Security Rules
// Covers only profiles/{userId} and usernames/{username}.
// Every Phase 1+ collection gets its own rules block when introduced.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ===== Profiles =====
    match /profiles/{userId} {
      allow read: if isAuthed();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['username', 'displayName', 'email', 'createdAt', 'lastSeen'])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 30;
      allow update: if isOwner(userId)
        // Username is immutable post-creation in Phase 0.
        && request.resource.data.username == resource.data.username;
      allow delete: if isOwner(userId);
    }

    // ===== Usernames (sentinel collection for uniqueness) =====
    // Public read so the sign-up form can do availability checks pre-auth.
    // Create requires the caller to be authed and the doc to point at their own uid.
    // Existence is checked atomically in a batched write — first-writer wins.
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isAuthed()
        && resource.data.uid == request.auth.uid;
    }

    // ===== Tribes (Phase 1) =====
    match /tribes/{tribeId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'createdBy', 'createdAt', 'memberCount'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.memberCount == 1;
      // Any member can nudge memberCount (join/leave). Name/creator are immutable.
      // Phase 4 moves the counter server-side; until then keep it permissive but bounded.
      allow update: if isAuthed()
        && request.resource.data.name == resource.data.name
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAuthed() && resource.data.createdBy == request.auth.uid;
    }

    // ===== Memberships (flat {uid}_{tribeId}) =====
    match /memberships/{membershipId} {
      allow read: if isAuthed();
      allow create: if isOwner(request.resource.data.uid);
      allow delete: if isAuthed() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ===== Embers (48h posts) =====
    match /embers/{emberId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll(['authorId', 'createdAt', 'expiresAt', 'echoCount'])
        && request.resource.data.echoCount == 0;
      // Counter bumps (echo/coldMark/extension) by any authed user. Author/text/createdAt immutable.
      // Phase 4 replaces this with Cloud Function writes for anti-gaming.
      allow update: if isAuthed()
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.text == resource.data.text;
      allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;

      // Echoes — one doc per user, keyed by uid.
      match /echoes/{userId} {
        allow read: if isAuthed();
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      // Cold marks — one doc per user, keyed by uid. Reports are write-once.
      match /coldMarks/{userId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // Whispers — comments. Anyone authed can read + add; only the author edits/removes.
      match /whispers/{whisperId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if false;
        allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;
      }

      // Poll votes — one write-once doc per user, keyed by uid (Quick Poll, F18).
      // The yes/no tally lives on the parent ember; this just guards one-vote-each.
      match /pollVotes/{userId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ===== Nest requests (friend requests) =====
    // Doc id is "{fromUid}_{toUid}". Only the two parties can see it. The sender
    // creates it (pending); the recipient resolves it; either side can remove it.
    match /nestRequests/{requestId} {
      allow read: if isAuthed()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
      allow create: if isAuthed()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.fromUserId != request.resource.data.toUserId
        && request.resource.data.keys().hasAll(['fromUserId', 'toUserId', 'createdAt']);
      // Only the recipient can change it; sender/recipient ids are immutable.
      allow update: if isAuthed()
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId;
      allow delete: if isAuthed()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
    }

    // ===== Nest membership (userNests/{userId}/members/{memberId}) =====
    // Membership is mutual: accepting writes BOTH userNests/me/members/them and
    // userNests/them/members/me. So a write is allowed when the caller owns either
    // side of the edge — they're the list owner (userId) or the member (memberId).
    match /userNests/{userId}/members/{memberId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && (request.auth.uid == userId || request.auth.uid == memberId);
      allow delete: if isAuthed()
        && (request.auth.uid == userId || request.auth.uid == memberId);
      allow update: if false;
    }

    // ===== Lanterns (anonymous 48h drift messages) =====
    match /lanterns/{lanternId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll(['authorId', 'createdAt', 'expiresAt', 'foundCount'])
        && request.resource.data.foundCount == 0;
      // foundCount bumps by any authed wanderer. Author is immutable.
      allow update: if isAuthed()
        && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;

      // Found marks — one doc per user, keyed by uid. Write-once.
      match /foundMarks/{userId} {
        allow read: if isAuthed();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ===== Expiring Embers (1:1 DMs) =====
    // chatId is the two uids sorted + joined "_". Only the two participants can
    // touch the chat or its messages. Message create is gated on the chat already
    // existing (the client upserts the chat first, then appends), so a stranger
    // can't seed a thread you never agreed to.
    match /chats/{chatId} {
      allow read: if isAuthed() && request.auth.uid in resource.data.participants;
      allow create: if isAuthed()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      // Updates (lastMessage summary, readBy) by either participant; the pair is fixed.
      allow update: if isAuthed()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthed()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthed()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Messages are immutable; the sender may remove their own.
        allow update: if false;
        allow delete: if isAuthed() && resource.data.senderId == request.auth.uid;
      }
    }

    // ===== Signals (notifications) =====
    // Inbox per user. Anyone authed may drop a Signal in your inbox (as themselves),
    // but only you can read, mark-read, or clear them.
    match /notifications/{userId}/items/{itemId} {
      allow read: if isOwner(userId);
      allow create: if isAuthed()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ===== Mood Canvas (daily mood, F12) =====
    // Anyone authed can read it (your aura shows to others when you opt in);
    // only you write your own days.
    match /moodCanvas/{userId}/days/{day} {
      allow read: if isAuthed();
      allow write: if isOwner(userId);
    }

    // ===== Deny by default for every other collection =====
    // Phase 2+ collections (ghostRooms/etc.) will add their own match blocks.
    // Until then, all access is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
